  <script>
    const defaultConfig = {
      store_name: "漫恩美學",
      store_subtitle: "接睫毛 ｜ 睫毛管理 ｜ 半永久 ｜ 眉毛淡色",
      background_color: "#FAF7F5",
      surface_color: "#FFFFFF",
      text_color: "#6B5B4F",
      primary_action_color: "#D4C4B7",
      secondary_action_color: "#A89B91"
    };

    const config = { ...defaultConfig };

    async function onConfigChange(cfg) {
      document.getElementById('store-name').textContent = cfg.store_name || defaultConfig.store_name;
      document.getElementById('store-subtitle').textContent = cfg.store_subtitle || defaultConfig.store_subtitle;

      const backgroundColor = cfg.background_color || defaultConfig.background_color;
      const surfaceColor = cfg.surface_color || defaultConfig.surface_color;
      const textColor = cfg.text_color || defaultConfig.text_color;
      const primaryActionColor = cfg.primary_action_color || defaultConfig.primary_action_color;
      const secondaryActionColor = cfg.secondary_action_color || defaultConfig.secondary_action_color;

      document.body.style.background = `linear-gradient(135deg, ${backgroundColor} 0%, ${adjustColor(backgroundColor, -10)} 50%, ${adjustColor(backgroundColor, 5)} 100%)`;
      
      document.querySelectorAll('.price-item, .info-card:not(.highlight)').forEach(el => {
        el.style.background = `rgba(${hexToRgb(surfaceColor)}, 0.95)`;
      });

      document.querySelectorAll('.section-title, .price-item-name, .info-card h3, .plan-title, h1').forEach(el => {
        el.style.color = textColor;
      });

      document.querySelectorAll('.contact-button, .quick-link-btn').forEach(btn => {
        btn.style.background = `linear-gradient(135deg, #FDFCFB 0%, ${surfaceColor} 100%)`;
      });

      document.querySelectorAll('.tab').forEach(tab => {
        if (!tab.classList.contains('active')) {
          tab.style.color = secondaryActionColor;
        }
      });
      document.querySelectorAll('.tab.active').forEach(tab => {
        tab.style.color = textColor;
      });

      document.querySelectorAll('.plan-amount, .price-item-price').forEach(el => {
        el.style.color = '#8B7E74';
      });
    }

    function hexToRgb(hex) {
      const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
      return result ? `${parseInt(result[1], 16)}, ${parseInt(result[2], 16)}, ${parseInt(result[3], 16)}` : '255, 255, 255';
    }

    function adjustColor(hex, percent) {
      const num = parseInt(hex.replace('#', ''), 16);
      const amt = Math.round(2.55 * percent);
      const R = Math.min(255, Math.max(0, (num >> 16) + amt));
      const G = Math.min(255, Math.max(0, (num >> 8 & 0x00FF) + amt));
      const B = Math.min(255, Math.max(0, (num & 0x0000FF) + amt));
      return '#' + (0x1000000 + (R << 16) + (G << 8) + B).toString(16).slice(1);
    }

    document.querySelectorAll('.tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const targetTab = tab.dataset.tab;
        
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        
        tab.classList.add('active');
        document.getElementById(targetTab).classList.add('active');
        
        onConfigChange(config);
      });
    });

    function setupSubTabs(selectorPrefix, panelPrefix) {
      document.querySelectorAll(`.${selectorPrefix}`).forEach(subTab => {
        subTab.addEventListener('click', () => {
          const targetSubTab = subTab.dataset.subtab;
          
          document.querySelectorAll(`.${selectorPrefix}`).forEach(t => {
            t.classList.remove('active');
          });
          
          document.querySelectorAll(`#${panelPrefix} .sub-tab-panel`).forEach(p => p.classList.remove('active'));
          
          subTab.classList.add('active');
          document.getElementById(targetSubTab).classList.add('active');
        });
      });
    }

    setupSubTabs('price-sub-tab', 'price');
    setupSubTabs('before-sub-tab', 'before');
    setupSubTabs('after-sub-tab', 'after');
    setupSubTabs('faq-sub-tab', 'faq');

    onConfigChange(config);
  </script>
